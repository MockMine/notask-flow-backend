# Notask Flow environment template.
# Copy this file to .env and fill in your own secrets before running docker-compose.
# Never commit real secrets.

# -------------------  Runtime  -------------------
# Spring active profile (dev | docker | prod)
SPRING_PROFILES_ACTIVE=docker
# Timezone for all containers
TZ=Asia/Hong_Kong

# -------------------  Hosts & Ports  -------------------
APP_HOST_PORT=8080

# Collaboration WebSocket
COLLAB_WS_HOST_PORT=8081
COLLAB_API_BASE_URL=http://host.docker.internal:8080
COLLAB_REALTIME_BROADCAST_URL=http://localhost:8081/internal/broadcast

# Frontend
FRONTEND_HOST_PORT=3000

# MySQL
MYSQL_HOST_PORT=3306
MYSQL_URL=jdbc:mysql://127.0.0.1:3306/notask_flow?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Hong_Kong

# Redis
REDIS_HOST=127.0.0.1
REDIS_HOST_PORT=6379

# RabbitMQ
RABBITMQ_HOST=127.0.0.1
RABBITMQ_HOST_PORT=5672
RABBITMQ_MANAGEMENT_HOST_PORT=15672

# MinIO
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001

# Elasticsearch
ELASTICSEARCH_ENDPOINT=http://127.0.0.1:9200
ELASTICSEARCH_HOST_PORT=9200

# -------------------  Data Directories  -------------------
MYSQL_DATA_DIR=/opt/mysql
REDIS_DATA_DIR=/opt/redis
RABBITMQ_DATA_DIR=/opt/rabbitmq
MINIO_DATA_DIR=/opt/minio

# -------------------  MySQL  -------------------
# Root password for MySQL container
MYSQL_ROOT_PASSWORD=notask
# Database name created on first init
MYSQL_DATABASE=notask_flow
# Application database user
MYSQL_USERNAME=notask
# Application database password
MYSQL_PASSWORD=notask

# -------------------  Redis  -------------------
# Redis password (leave empty to disable auth)
REDIS_PASSWORD=notask
# Redis database index (0-15)
REDIS_DATABASE=0

# -------------------  RabbitMQ  -------------------
# RabbitMQ default user
RABBITMQ_USERNAME=notask
# RabbitMQ default password
RABBITMQ_PASSWORD=notask

# -------------------  MinIO  -------------------
# MinIO access key (also used as root user)
MINIO_ACCESS_KEY=minioadmin
# MinIO secret key (also used as root password)
MINIO_SECRET_KEY=minioadmin
# Default bucket name, created automatically on first run
MINIO_BUCKET=notask-flow

# -------------------  Elasticsearch  -------------------
# JVM heap size for Elasticsearch
ES_JAVA_OPTS=-Xms512m -Xmx512m
# Enable or disable Elasticsearch integration
ELASTICSEARCH_ENABLED=true
# Elasticsearch client connection timeout
ELASTICSEARCH_CONNECTION_TIMEOUT=3s
# Elasticsearch client socket timeout
ELASTICSEARCH_SOCKET_TIMEOUT=3s

# -------------------  Sa-Token / JWT  -------------------
# JWT signing secret (at least 32 characters, change in production)
SA_TOKEN_JWT_SECRET=change-me-to-a-long-random-jwt-secret
# Reuse the same token when the same account logs in repeatedly
SA_TOKEN_IS_SHARE=false

# -------------------  Collaboration Service (collab-ws)  -------------------
# Internal token shared between backend and collab-ws for service-to-service calls
COLLAB_INTERNAL_TOKEN=change-me-to-a-long-random-internal-token

# -------------------  Frontend Build  -------------------
# API base URL used at frontend build time (VITE_API_BASE_URL)
FRONTEND_API_BASE_URL=/api/v1
# WebSocket URL used at frontend build time (VITE_COLLAB_WS_URL)
FRONTEND_COLLAB_WS_URL=/ws

# -------------------  Mail (optional)  -------------------
# Sender address for outgoing emails
NOTASK_MAIL_FROM=change-me-email(no-reply@notask-flow.local)
# Public base URL used in generated email links
NOTASK_APP_BASE_URL=http://localhost:3000
# SMTP server hostname
MAIL_HOST=smtp.163.com
# SMTP server port
MAIL_PORT=465
# SMTP authentication username
MAIL_USERNAME=change-me-email(no-reply@notask-flow.local)
# SMTP authentication password
MAIL_PASSWORD=change-me-email-password
# Enable SMTP authentication
MAIL_SMTP_AUTH=true
# Enable SSL for SMTP
MAIL_SMTP_SSL_ENABLE=true
# Enable STARTTLS for SMTP
MAIL_SMTP_STARTTLS_ENABLE=false
# SMTP connection timeout in milliseconds
MAIL_SMTP_CONNECTION_TIMEOUT=5000
# SMTP read timeout in milliseconds
MAIL_SMTP_TIMEOUT=5000
# SMTP write timeout in milliseconds
MAIL_SMTP_WRITE_TIMEOUT=5000

# -------------------  Invite  -------------------
# Default expiry time in minutes for team invite links
INVITE_DEFAULT_EXPIRE_MINUTES=30

# -------------------  File Management  -------------------
# Maximum upload file size in bytes (524288000 = 500 MB)
FILE_MAX_SIZE=524288000
# Enable scheduled cleanup of trashed files
FILE_CLEANUP_ENABLED=true
# Cron expression for file cleanup job
FILE_CLEANUP_CRON=0 0 3 * * *
# Days to retain files in trash before permanent deletion
FILE_TRASH_RETENTION_DAYS=30
# Number of files to delete per cleanup batch
FILE_CLEANUP_BATCH_SIZE=100
# Files larger than this (in bytes) will use chunked upload (52428800 = 50 MB)
FILE_MULTIPART_THRESHOLD_SIZE=52428800
# Size of each chunk in bytes during chunked upload (5242880 = 5 MB)
FILE_CHUNK_SIZE=5242880
# Minutes before an incomplete chunked upload session expires
FILE_CHUNK_UPLOAD_SESSION_MINUTES=30
# Temporary directory for chunked uploads (empty = system default)
FILE_CHUNK_TEMP_DIR=
